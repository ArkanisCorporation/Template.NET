{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
       {
           "name": "prepare-shell-scripts",
           "group": "pre-commit",
           "command": "bash",
           "args": [ "scripts/prepare-shell-scripts.sh" ],
           "windows": {
               "command": "powershell",
               "args": [ "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/prepare-shell-scripts.ps1" ]
           }
       },
       {
           "name": "update-shell-script-permissions",
           "command": "bash",
           "args": [ "scripts/update-shell-script-permissions.sh" ],
           "windows": {
               "command": "powershell",
               "args": [ "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/update-shell-script-permissions.ps1" ]
           }
       },
       {
           "name": "dotnet-format-check",
           "group": "pre-commit",
           "command": "dotnet",
           "args": [ "format", "Template.slnx", "--verify-no-changes", "--verbosity", "diagnostic", "--no-restore" ]
       },
       {
           "name": "dotnet-format",
           "command": "dotnet",
           "args": [ "format", "Template.slnx", "--verbosity", "diagnostic", "--no-restore" ]
       }
   ]
}
